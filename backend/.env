# ─── EduBrain AI — Environment Variables ─────────────────────────────────────
# Copy this to .env and fill in your values

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Database ─────────────────────────────────────────────────────────────────
# MongoDB Atlas (recommended for production)
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/edubrain?retryWrites=true&w=majority

# Or local MongoDB
MONGO_URI=mongodb://localhost:27017/edubrain

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars_dummy_for_testing_12345678901234567890

# ── AI (Google Gemini) ────────────────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza_your_gemini_api_key_here

# ── Cloudinary (File Storage) ─────────────────────────────────────────────────
# Get from: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Gmail: enable 2FA → App Passwords → generate
SMTP_HOST=smtp.gmail.com
SMTP_USER=your_school@gmail.com
SMTP_PASS=your_app_password_here

# ── SMS (Twilio) ──────────────────────────────────────────────────────────────
# Get from: https://www.twilio.com
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=your_auth_token
TWILIO_FROM=+1234567890

# ── WhatsApp Business API ─────────────────────────────────────────────────────
# Get from: https://developers.facebook.com/docs/whatsapp
WA_TOKEN=your_whatsapp_business_token
WA_PHONE_ID=your_phone_number_id

# ── Firebase (Push Notifications) ────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → Cloud Messaging
FCM_SERVER_KEY=your_fcm_server_key

# ── Razorpay (Fee Payment Gateway) ───────────────────────────────────────────
# Get from: https://razorpay.com
RAZORPAY_KEY=rzp_live_your_key_id
RAZORPAY_SECRET=your_razorpay_secret

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://edubrain.in,https://www.edubrain.in

# ── Rate Limits ───────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200
